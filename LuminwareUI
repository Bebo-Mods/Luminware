-- ── DROPDOWN ──────────────────────────────────────────────
function BaseGroupbox:AddDropdown(Idx, Info)
    assert(Info.Values,                              "AddDropdown: Missing `Values`.")
    assert(Info.AllowNull or Info.Default ~= nil,   "AddDropdown: Missing `Default`. Use `AllowNull = true` if intentional.")

    local Dropdown = {
        Values   = Info.Values;
        Value    = Info.Multi and {} or nil;
        Multi    = Info.Multi;
        Type     = "Dropdown";
        Callback = Info.Callback or function() end;
    }

    if not Info.Compact and Info.Text then
        Phantom:CreateLabel({
            Size           = UDim2.new(1,0,0,13);
            TextSize       = 13;
            Text           = Info.Text;
            TextXAlignment = Enum.TextXAlignment.Left;
            TextYAlignment = Enum.TextYAlignment.Bottom;
            ZIndex         = 5;
            Parent         = self.Container;
        })
        self:AddBlank(2)
    end

    local DropOuter = Phantom:Create("Frame", {
        BackgroundColor3 = Phantom.Black;
        BorderColor3     = Phantom.Black;
        Size             = UDim2.new(1,-4,0,20);
        ZIndex           = 5;
        Parent           = self.Container;
    })
    local DropInner = Phantom:Create("Frame", {
        BackgroundColor3 = Phantom.MainColor;
        BorderColor3     = Phantom.OutlineColor;
        BorderMode       = Enum.BorderMode.Inset;
        Size             = UDim2.new(1,0,1,0);
        ZIndex           = 6;
        Parent           = DropOuter;
    })
    Phantom:Create("UIGradient", {
        Color    = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.new(1,1,1)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(212,212,212)),
        });
        Rotation = 90;
        Parent   = DropInner;
    })
    Phantom:AddToRegistry(DropOuter, { BorderColor3 = "Black" })
    Phantom:AddToRegistry(DropInner, { BackgroundColor3 = "MainColor"; BorderColor3 = "OutlineColor" })
    Phantom:OnHighlight(DropOuter, DropOuter,
        { BorderColor3 = "AccentColor" },
        { BorderColor3 = "Black" }
    )

    local Arrow = Phantom:Create("ImageLabel", {
        AnchorPoint          = Vector2.new(0,0.5);
        BackgroundTransparency = 1;
        Position             = UDim2.new(1,-16,0.5,0);
        Size                 = UDim2.new(0,12,0,12);
        Image                = "rbxassetid://6282522798";
        ZIndex               = 8;
        Parent               = DropInner;
    })

    local ItemLabel = Phantom:CreateLabel({
        Position       = UDim2.new(0,5,0,0);
        Size           = UDim2.new(1,-20,1,0);
        TextSize       = 13;
        Text           = "--";
        TextXAlignment = Enum.TextXAlignment.Left;
        TextWrapped    = true;
        ZIndex         = 7;
        Parent         = DropInner;
    })

    if type(Info.Tooltip) == "string" then
        Phantom:AddToolTip(Info.Tooltip, DropOuter)
    end

    -- List frame (lives in ScreenGui so it overlays everything)
    local MAX_ITEMS = 8

    local ListOuter = Phantom:Create("Frame", {
        BackgroundColor3 = Phantom.Black;
        BorderColor3     = Phantom.Black;
        ZIndex           = 20;
        Visible          = false;
        Parent           = ScreenGui;
    })

    local ListInner = Phantom:Create("Frame", {
        BackgroundColor3 = Phantom.MainColor;
        BorderColor3     = Phantom.OutlineColor;
        BorderMode       = Enum.BorderMode.Inset;
        Size             = UDim2.new(1,0,1,0);
        ZIndex           = 21;
        Parent           = ListOuter;
    })
    Phantom:AddToRegistry(ListInner, { BackgroundColor3 = "MainColor"; BorderColor3 = "OutlineColor" })

    local Scrolling = Phantom:Create("ScrollingFrame", {
        BackgroundTransparency = 1;
        BorderSizePixel        = 0;
        CanvasSize             = UDim2.new(0,0,0,0);
        Size                   = UDim2.new(1,0,1,0);
        ZIndex                 = 21;
        TopImage               = "rbxasset://textures/ui/Scroll/scroll-middle.png";
        BottomImage            = "rbxasset://textures/ui/Scroll/scroll-middle.png";
        ScrollBarThickness     = 3;
        ScrollBarImageColor3   = Phantom.AccentColor;
        Parent                 = ListInner;
    })
    Phantom:AddToRegistry(Scrolling, { ScrollBarImageColor3 = "AccentColor" })

    Phantom:Create("UIListLayout", {
        FillDirection = Enum.FillDirection.Vertical;
        SortOrder     = Enum.SortOrder.LayoutOrder;
        Parent        = Scrolling;
    })

    local function RecalcPos()
        ListOuter.Position = UDim2.fromOffset(
            DropOuter.AbsolutePosition.X,
            DropOuter.AbsolutePosition.Y + DropOuter.Size.Y.Offset + 1
        )
    end
    local function RecalcSize(Y)
        ListOuter.Size = UDim2.fromOffset(
            DropOuter.AbsoluteSize.X,
            Y or (MAX_ITEMS * 20 + 2)
        )
    end
    RecalcPos(); RecalcSize()
    DropOuter:GetPropertyChangedSignal("AbsolutePosition"):Connect(RecalcPos)

    function Dropdown:Display()
        local Str = ""
        if Info.Multi then
            for _, v in next, self.Values do
                if self.Value[v] then Str = Str .. v .. ", " end
            end
            Str = Str:sub(1, #Str-2)
        else
            Str = self.Value or ""
        end
        ItemLabel.Text = Str == "" and "--" or Str
    end

    function Dropdown:BuildList()
        for _, c in next, Scrolling:GetChildren() do
            if not c:IsA("UIListLayout") then c:Destroy() end
        end
        local Buttons = {}
        local Count   = 0

        for _, Value in next, self.Values do
            Count = Count + 1
            local Btn = Phantom:Create("Frame", {
                BackgroundColor3 = Phantom.MainColor;
                BorderColor3     = Phantom.OutlineColor;
                BorderMode       = Enum.BorderMode.Middle;
                Size             = UDim2.new(1,-1,0,20);
                ZIndex           = 23;
                Active           = true;
                Parent           = Scrolling;
            })
            Phantom:AddToRegistry(Btn, { BackgroundColor3 = "MainColor"; BorderColor3 = "OutlineColor" })

            local BtnLabel = Phantom:CreateLabel({
                Size           = UDim2.new(1,-6,1,0);
                Position       = UDim2.new(0,6,0,0);
                TextSize       = 13;
                Text           = Value;
                TextXAlignment = Enum.TextXAlignment.Left;
                ZIndex         = 24;
                Parent         = Btn;
            })
            Phantom:OnHighlight(Btn, Btn,
                { BorderColor3 = "AccentColor" },
                { BorderColor3 = "OutlineColor" }
            )

            local Selected = Info.Multi and self.Value[Value] or (self.Value == Value)

            local Table = {}
            function Table:UpdateButton()
                Selected = Info.Multi and Dropdown.Value[Value] or (Dropdown.Value == Value)
                BtnLabel.TextColor3 = Selected and Phantom.AccentColor or Phantom.FontColor
                local Reg = Phantom.RegistryMap[BtnLabel]
                if Reg then
                    Reg.Properties.TextColor3 = Selected and "AccentColor" or "FontColor"
                end
            end

            BtnLabel.InputBegan:Connect(function(Input)
                if Input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
                local Try = not Selected
                if Info.Multi then
                    Selected = Try
                    if Selected then self.Value[Value] = true else self.Value[Value] = nil end
                else
                    if not Try and not Info.AllowNull then return end
                    Selected = Try
                    self.Value = Selected and Value or nil
                    for _, OB in next, Buttons do OB:UpdateButton() end
                end
                Table:UpdateButton()
                self:Display()
                Phantom:SafeCallback(self.Callback, self.Value)
                Phantom:SafeCallback(self.Changed, self.Value)
                Phantom:AttemptSave()
            end)

            Table:UpdateButton()
            Buttons[Btn] = Table
        end

        Scrolling.CanvasSize = UDim2.fromOffset(0, Count * 20 + 1)
        RecalcSize(math.clamp(Count * 20, 0, MAX_ITEMS * 20) + 1)
        self:Display()
    end

    function Dropdown:Open()
        self:BuildList()
        ListOuter.Visible = true
        Phantom.OpenedFrames[ListOuter] = true
        Arrow.Rotation = 180
    end

    function Dropdown:Close()
        ListOuter.Visible = false
        Phantom.OpenedFrames[ListOuter] = nil
        Arrow.Rotation = 0
    end

    function Dropdown:SetValues(NewValues)
        if NewValues then self.Values = NewValues end
        self:BuildList()
    end

    function Dropdown:SetValue(Val)
        if self.Multi then
            local New = {}
            for v in next, Val do
                if table.find(self.Values, v) then New[v] = true end
            end
            self.Value = New
        else
            if not Val then
                self.Value = nil
            elseif table.find(self.Values, Val) then
                self.Value = Val
            end
        end
        self:BuildList()
        Phantom:SafeCallback(self.Callback, self.Value)
        Phantom:SafeCallback(self.Changed, self.Value)
    end

    function Dropdown:OnChanged(Func)
        self.Changed = Func
        Func(self.Value)
    end

    DropOuter.InputBegan:Connect(function(Input)
        if Input.UserInputType ~= Enum.UserInputType.MouseButton1
        or Phantom:MouseIsOverOpenedFrame() then return end
        if ListOuter.Visible then Dropdown:Close() else Dropdown:Open() end
    end)

    Phantom:GiveSignal(InputService.InputBegan:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 then
            if not Phantom:IsMouseOverFrame(ListOuter)
            and not Phantom:IsMouseOverFrame(DropOuter) then
                Dropdown:Close()
            end
        end
    end))

    -- Apply defaults
    if Info.Default ~= nil then
        if Info.Multi then
            local Defaults = type(Info.Default) == "table" and Info.Default or { Info.Default }
            for _, v in next, Defaults do
                if table.find(Dropdown.Values, v) then
                    Dropdown.Value[v] = true
                end
            end
        else
            if table.find(Dropdown.Values, Info.Default) then
                Dropdown.Value = Info.Default
            end
        end
    end

    Dropdown:BuildList()
    Dropdown:Display()

    self:AddBlank(Info.BlankSize or 4)
    self:Resize()

    Options[Idx] = Dropdown
    return Dropdown
end

