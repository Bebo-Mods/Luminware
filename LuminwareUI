    if Textbox.Finished then
        Box.FocusLost:Connect(function(enter)
            if not enter then return end
            Textbox:SetValue(Box.Text)
            Phantom:AttemptSave()
        end)
    else
        Box:GetPropertyChangedSignal("Text"):Connect(function()
            Textbox:SetValue(Box.Text)
        end)
    end

    self:AddBlank(4)
