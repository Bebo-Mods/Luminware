-- ── BLANK SPACER ──────────────────────────────────────────
function BaseGroupbox:AddBlank(Size)
    Phantom:Create("Frame", {
        BackgroundTransparency = 1;
        Size                   = UDim2.new(1,0,0,Size);
        ZIndex                 = 1;
        Parent                 = self.Container;
    })
