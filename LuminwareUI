        })
        Phantom:AddToRegistry(TabBtn, { BackgroundColor3 = "BackgroundColor"; BorderColor3 = "OutlineColor" })

        local TabBtnLabel = Phantom:CreateLabel({
            Size           = UDim2.new(1,0,1,-1);
            Text           = Name;
            TextSize       = 14;
            ZIndex         = 1;
            Parent         = TabBtn;
        })

        local Blocker = Phantom:Create("Frame", {
            BackgroundColor3     = Phantom.MainColor;
            BorderSizePixel      = 0;
            Position             = UDim2.new(0,0,1,0);
            Size                 = UDim2.new(1,0,0,1);
            BackgroundTransparency = 1;
            ZIndex               = 3;
            Parent               = TabBtn;
        })
        Phantom:AddToRegistry(Blocker, { BackgroundColor3 = "MainColor" })

        local TabFrame = Phantom:Create("Frame", {
            Name                 = "TabFrame";
            BackgroundTransparency = 1;
            Size                 = UDim2.new(1,0,1,0);
            Visible              = false;
            ZIndex               = 2;
            Parent               = TabContainer;
        })

        local function MakeSide(xPos, xSize)
            local S = Phantom:Create("ScrollingFrame", {
                BackgroundTransparency = 1;
                BorderSizePixel        = 0;
                Position               = UDim2.new(xPos, 0, 0, 8);
                Size                   = UDim2.new(xSize, -12, 1, -16);
                CanvasSize             = UDim2.new(0,0,0,0);
                BottomImage            = "";
                TopImage               = "";
                ScrollBarThickness     = 0;
                ZIndex                 = 2;
                Parent                 = TabFrame;
            })
            Phantom:Create("UIListLayout", {
                Padding              = UDim.new(0,8);
                FillDirection        = Enum.FillDirection.Vertical;
                SortOrder            = Enum.SortOrder.LayoutOrder;
                HorizontalAlignment  = Enum.HorizontalAlignment.Center;
                Parent               = S;
            })
            S:FindFirstChildOfClass("UIListLayout"):GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                S.CanvasSize = UDim2.fromOffset(0, S:FindFirstChildOfClass("UIListLayout").AbsoluteContentSize.Y)
            end)
            return S
        end

        local LeftSide  = MakeSide(0,   0.5)
        local RightSide = MakeSide(0.5, 0.5)

        function Tab:ShowTab()
            for _, T in next, Window.Tabs do T:HideTab() end
            Blocker.BackgroundTransparency = 0
            TabBtn.BackgroundColor3 = Phantom.MainColor
            Phantom.RegistryMap[TabBtn].Properties.BackgroundColor3 = "MainColor"
            TabFrame.Visible = true
        end

        function Tab:HideTab()
            Blocker.BackgroundTransparency = 1
            TabBtn.BackgroundColor3 = Phantom.BackgroundColor
            Phantom.RegistryMap[TabBtn].Properties.BackgroundColor3 = "BackgroundColor"
            TabFrame.Visible = false
        end

        -- ── ADD GROUPBOX ────────────────────────────────
        local function AddGroupbox(Info)
            local GB = {}

            local Side = Info.Side == 1 and LeftSide or RightSide

            local BoxOuter = Phantom:Create("Frame", {
                BackgroundColor3 = Phantom.BackgroundColor;
                BorderColor3     = Phantom.OutlineColor;
                BorderMode       = Enum.BorderMode.Inset;
                Size             = UDim2.new(1,0,0,40);
                ZIndex           = 2;
                Parent           = Side;
            })
            Phantom:AddToRegistry(BoxOuter, { BackgroundColor3 = "BackgroundColor"; BorderColor3 = "OutlineColor" })

            local BoxInner = Phantom:Create("Frame", {
                BackgroundColor3 = Phantom.BackgroundColor;
                BorderColor3     = Phantom.Black;
                Size             = UDim2.new(1,-2,1,-2);
                Position         = UDim2.new(0,1,0,1);
                ZIndex           = 4;
                Parent           = BoxOuter;
            })
            Phantom:AddToRegistry(BoxInner, { BackgroundColor3 = "BackgroundColor" })

            local Accent = Phantom:Create("Frame", {
                BackgroundColor3 = Phantom.AccentColor;
                BorderSizePixel  = 0;
                Size             = UDim2.new(1,0,0,2);
                ZIndex           = 5;
                Parent           = BoxInner;
            })
            Phantom:AddToRegistry(Accent, { BackgroundColor3 = "AccentColor" })

            Phantom:CreateLabel({
                Size           = UDim2.new(1,0,0,18);
                Position       = UDim2.new(0,4,0,2);
                TextSize       = 13;
                Text           = Info.Name;
                TextXAlignment = Enum.TextXAlignment.Left;
                ZIndex         = 5;
                Parent         = BoxInner;
            })

            local Container = Phantom:Create("Frame", {
                BackgroundTransparency = 1;
                Position               = UDim2.new(0,4,0,20);
                Size                   = UDim2.new(1,-4,1,-20);
                ZIndex                 = 1;
                Parent                 = BoxInner;
            })
            Phantom:Create("UIListLayout", {
                FillDirection = Enum.FillDirection.Vertical;
                SortOrder     = Enum.SortOrder.LayoutOrder;
                Parent        = Container;
            })

            function GB:Resize()
                local H = 0
                for _, E in next, self.Container:GetChildren() do
                    if not E:IsA("UIListLayout") and E.Visible then
                        H = H + E.Size.Y.Offset
                    end
                end
                BoxOuter.Size = UDim2.new(1,0,0, 22+H+4)
            end

            GB.Container = Container
            setmetatable(GB, BaseGroupbox)

            GB:AddBlank(3)
            GB:Resize()

            Tab.Groupboxes[Info.Name] = GB
            return GB
        end

        function Tab:AddLeftGroupbox(Name)
            return AddGroupbox({ Side=1, Name=Name })
        end
        function Tab:AddRightGroupbox(Name)
            return AddGroupbox({ Side=2, Name=Name })
        end

        -- ── ADD TABBOX ──────────────────────────────────
        local function AddTabbox(Info)
            local Tabbox = { Tabs = {} }
            local Side   = Info.Side == 1 and LeftSide or RightSide

            local BoxOuter = Phantom:Create("Frame", {
                BackgroundColor3 = Phantom.BackgroundColor;
                BorderColor3     = Phantom.OutlineColor;
                BorderMode       = Enum.BorderMode.Inset;
                Size             = UDim2.new(1,0,0,0);
                ZIndex           = 2;
                Parent           = Side;
            })
            Phantom:AddToRegistry(BoxOuter, { BackgroundColor3 = "BackgroundColor"; BorderColor3 = "OutlineColor" })

            local BoxInner = Phantom:Create("Frame", {
                BackgroundColor3 = Phantom.BackgroundColor;
                BorderColor3     = Phantom.Black;
                Size             = UDim2.new(1,-2,1,-2);
                Position         = UDim2.new(0,1,0,1);
                ZIndex           = 4;
                Parent           = BoxOuter;
            })
            Phantom:AddToRegistry(BoxInner, { BackgroundColor3 = "BackgroundColor" })

            local Accent = Phantom:Create("Frame", {
                BackgroundColor3 = Phantom.AccentColor;
                BorderSizePixel  = 0;
                Size             = UDim2.new(1,0,0,2);
                ZIndex           = 10;
                Parent           = BoxInner;
            })
            Phantom:AddToRegistry(Accent, { BackgroundColor3 = "AccentColor" })

            local BtnRow = Phantom:Create("Frame", {
                BackgroundTransparency = 1;
                Position               = UDim2.new(0,0,0,1);
                Size                   = UDim2.new(1,0,0,18);
                ZIndex                 = 5;
                Parent                 = BoxInner;
            })
            Phantom:Create("UIListLayout", {
                FillDirection        = Enum.FillDirection.Horizontal;
                HorizontalAlignment  = Enum.HorizontalAlignment.Left;
                SortOrder            = Enum.SortOrder.LayoutOrder;
                Parent               = BtnRow;
            })

            function Tabbox:AddTab(TName)
                local TTab = {}

                local Btn = Phantom:Create("Frame", {
                    BackgroundColor3 = Phantom.MainColor;
                    BorderColor3     = Phantom.Black;
                    Size             = UDim2.new(0.5,0,1,0);
                    ZIndex           = 6;
                    Parent           = BtnRow;
                })
                Phantom:AddToRegistry(Btn, { BackgroundColor3 = "MainColor" })

                Phantom:CreateLabel({
                    Size     = UDim2.new(1,0,1,0);
                    TextSize = 13;
                    Text     = TName;
                    ZIndex   = 7;
                    Parent   = Btn;
                })

                local Block = Phantom:Create("Frame", {
                    BackgroundColor3 = Phantom.BackgroundColor;
                    BorderSizePixel  = 0;
                    Position         = UDim2.new(0,0,1,0);
                    Size             = UDim2.new(1,0,0,1);
                    Visible          = false;
                    ZIndex           = 9;
                    Parent           = Btn;
                })
                Phantom:AddToRegistry(Block, { BackgroundColor3 = "BackgroundColor" })

                local Cont = Phantom:Create("Frame", {
                    BackgroundTransparency = 1;
                    Position               = UDim2.new(0,4,0,20);
                    Size                   = UDim2.new(1,-4,1,-20);
                    ZIndex                 = 1;
                    Visible                = false;
                    Parent                 = BoxInner;
                })
                Phantom:Create("UIListLayout", {
                    FillDirection = Enum.FillDirection.Vertical;
                    SortOrder     = Enum.SortOrder.LayoutOrder;
                    Parent        = Cont;
                })

                function TTab:Show()
                    for _, T in next, Tabbox.Tabs do T:Hide() end
                    Cont.Visible  = true
                    Block.Visible = true
                    Btn.BackgroundColor3 = Phantom.BackgroundColor
                    Phantom.RegistryMap[Btn].Properties.BackgroundColor3 = "BackgroundColor"
                    TTab:Resize()
                end

                function TTab:Hide()
                    Cont.Visible  = false
                    Block.Visible = false
                    Btn.BackgroundColor3 = Phantom.MainColor
                    Phantom.RegistryMap[Btn].Properties.BackgroundColor3 = "MainColor"
                end

                function TTab:Resize()
                    local Count = 0
                    for _ in next, Tabbox.Tabs do Count = Count + 1 end
                    for _, B in next, BtnRow:GetChildren() do
                        if not B:IsA("UIListLayout") then
                            B.Size = UDim2.new(1/Count,0,1,0)
                        end
                    end
                    if not Cont.Visible then return end
                    local H = 0
                    for _, E in next, TTab.Container:GetChildren() do
                        if not E:IsA("UIListLayout") and E.Visible then
                            H = H + E.Size.Y.Offset
                        end
                    end
                    BoxOuter.Size = UDim2.new(1,0,0,22+H+4)
                end

                Btn.InputBegan:Connect(function(Input)
                    if Input.UserInputType == Enum.UserInputType.MouseButton1
                    and not Phantom:MouseIsOverOpenedFrame() then
                        TTab:Show()
                    end
                end)

                TTab.Container = Cont
                Tabbox.Tabs[TName] = TTab
                setmetatable(TTab, BaseGroupbox)
                TTab:AddBlank(3)
                TTab:Resize()

                -- Show first tab automatically
                if #BtnRow:GetChildren() == 2 then TTab:Show() end

                return TTab
            end

            Tab.Tabboxes[Info.Name or ""] = Tabbox
            return Tabbox
        end

        function Tab:AddLeftTabbox(Name)
            return AddTabbox({ Name=Name, Side=1 })
        end
        function Tab:AddRightTabbox(Name)
            return AddTabbox({ Name=Name, Side=2 })
        end

        TabBtn.InputBegan:Connect(function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 then
                Tab:ShowTab()
            end
        end)

        if #TabContainer:GetChildren() == 1 then Tab:ShowTab() end

        Window.Tabs[Name] = Tab
        return Tab
    end

    -- ── TOGGLE (show/hide with fade) ─────────────────────
    local TransparencyCache = {}
    local Toggled           = false
    local Fading            = false

    function self:Toggle()
        if Fading then return end
        local FadeTime = Config.MenuFadeTime
        Fading  = true
        Toggled = not Toggled

        if Toggled then
            Outer.Visible = true
        end

        for _, Desc in next, Outer:GetDescendants() do
            local Props = {}
            if Desc:IsA("ImageLabel") or Desc:IsA("ImageButton") then
                table.insert(Props, "ImageTransparency")
                table.insert(Props, "BackgroundTransparency")
            elseif Desc:IsA("TextLabel") or Desc:IsA("TextBox") or Desc:IsA("TextButton") then
                table.insert(Props, "TextTransparency")
                table.insert(Props, "BackgroundTransparency")
            elseif Desc:IsA("Frame") or Desc:IsA("ScrollingFrame") then
                table.insert(Props, "BackgroundTransparency")
            elseif Desc:IsA("UIStroke") then
                table.insert(Props, "Transparency")
            end

            local Cache = TransparencyCache[Desc]
            if not Cache then Cache = {}; TransparencyCache[Desc] = Cache end

            for _, Prop in next, Props do
                if not Cache[Prop] then Cache[Prop] = Desc[Prop] end
                if Cache[Prop] == 1 then continue end
                TweenService:Create(Desc, TweenInfo.new(FadeTime, Enum.EasingStyle.Linear), {
                    [Prop] = Toggled and Cache[Prop] or 1
                }):Play()
            end
        end

        task.wait(FadeTime)
        Outer.Visible = Toggled
        Fading        = false
    end

    -- Global toggle keybind
    Phantom:GiveSignal(InputService.InputBegan:Connect(function(Input, Processed)
        if type(Phantom.ToggleKeybind) == "table" and Phantom.ToggleKeybind.Type == "KeyPicker" then
            if Input.UserInputType == Enum.UserInputType.Keyboard
            and Input.KeyCode.Name == Phantom.ToggleKeybind.Value then
                task.spawn(function() Phantom:Toggle() end)
            end
        elseif Input.KeyCode == Enum.KeyCode.RightControl
        or (Input.KeyCode == Enum.KeyCode.RightShift and not Processed) then
            task.spawn(function() Phantom:Toggle() end)
        end
    end))

    -- Store reference for Toggle
    Phantom._currentWindow = Window
    function Phantom:Toggle()
        if Window then
            local fn = Window._toggle
            if fn then fn() end
        end
    end
    Window._toggle = function()
        if Fading then return end
        local FadeTime = Config.MenuFadeTime
        Fading  = true
        Toggled = not Toggled
        if Toggled then Outer.Visible = true end
        for _, Desc in next, Outer:GetDescendants() do
            local Props = {}
            if Desc:IsA("ImageLabel") then table.insert(Props,"ImageTransparency"); table.insert(Props,"BackgroundTransparency")
            elseif Desc:IsA("TextLabel") or Desc:IsA("TextBox") then table.insert(Props,"TextTransparency")
            elseif Desc:IsA("Frame") or Desc:IsA("ScrollingFrame") then table.insert(Props,"BackgroundTransparency")
            elseif Desc:IsA("UIStroke") then table.insert(Props,"Transparency") end
            local Cache = TransparencyCache[Desc]
            if not Cache then Cache = {}; TransparencyCache[Desc] = Cache end
            for _, Prop in next, Props do
                if not Cache[Prop] then Cache[Prop] = Desc[Prop] end
                if Cache[Prop] == 1 then continue end
                TweenService:Create(Desc, TweenInfo.new(FadeTime,Enum.EasingStyle.Linear),{
                    [Prop] = Toggled and Cache[Prop] or 1
                }):Play()
            end
        end
        task.wait(FadeTime)
        Outer.Visible = Toggled
        Fading = false
    end

    if Config.AutoShow then task.spawn(Window._toggle) end

    Window.Holder = Outer
    return Window
end

