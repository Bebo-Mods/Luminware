end

-- ============================================================
-- THEME SYSTEM
-- ============================================================
function Phantom:SetTheme(ThemeNameOrColor)
    local Color = self.Themes[ThemeNameOrColor] or ThemeNameOrColor
    if typeof(Color) ~= "Color3" then
        return warn("[PhantomUI] Invalid theme: " .. tostring(ThemeNameOrColor))
    end
    self.AccentColor     = Color
    self.AccentColorDark = self:GetDarkerColor(Color)
    self:UpdateColorsUsingRegistry()

    -- Flash effect on all windows
    for _, Outer in next, self._windows or {} do
        local flash = self:Create("Frame", {
            Size                   = UDim2.new(1,0,1,0);
            BackgroundColor3       = Color3.new(1,1,1);
            BackgroundTransparency = 0.88;
            BorderSizePixel        = 0;
            ZIndex                 = 200;
            Parent                 = Outer;
        })
        TweenService:Create(flash, TweenInfo.new(0.22, Enum.EasingStyle.Linear), {
            BackgroundTransparency = 1
        }):Play()
        task.delay(0.22, function() flash:Destroy() end)
    end
end

Phantom._windows = {}

