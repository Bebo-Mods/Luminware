-- ── SECTION DIVIDER ───────────────────────────────────────
function BaseGroupbox:AddSection(Text)
    local Row = Phantom:Create("Frame", {
        BackgroundTransparency = 1;
        Size                   = UDim2.new(1,0,0,24);
        ZIndex                 = 3;
        Parent                 = self.Container;
    })
    local Label = Phantom:CreateLabel({
        Size           = UDim2.new(0,80,1,0);
        TextSize       = 10;
        Text           = Text;
        TextColor3     = Phantom.OutlineColor;
        TextXAlignment = Enum.TextXAlignment.Left;
        ZIndex         = 4;
        Parent         = Row;
    })
    Phantom:RemoveFromRegistry(Label)
    Phantom:AddToRegistry(Label, { TextColor3 = "OutlineColor" })

    Phantom:Create("Frame", {
        AnchorPoint      = Vector2.new(1,0.5);
        Position         = UDim2.new(1,0,0.5,0);
        Size             = UDim2.new(1,-88,0,1);
        BackgroundColor3 = Phantom.OutlineColor;
        BorderSizePixel  = 0;
        ZIndex           = 4;
        Parent           = Row;
    })

    self:Resize()
end

-- ── LABEL ─────────────────────────────────────────────────
function BaseGroupbox:AddLabel(Text, Wrap)
    local Label = {}
    local TextLabel = Phantom:CreateLabel({
        Size           = UDim2.new(1,-4,0,14);
        TextSize       = 13;
        Text           = Text;
        TextWrapped    = Wrap or false;
        TextXAlignment = Enum.TextXAlignment.Left;
        ZIndex         = 5;
        Parent         = self.Container;
    })
    if not Wrap then
        Phantom:Create("UIListLayout", {
            Padding              = UDim.new(0,4);
            FillDirection        = Enum.FillDirection.Horizontal;
            HorizontalAlignment  = Enum.HorizontalAlignment.Right;
            SortOrder            = Enum.SortOrder.LayoutOrder;
            Parent               = TextLabel;
        })
    end
    Label.TextLabel = TextLabel
    Label.Container = self.Container
    function Label:SetText(t)
        TextLabel.Text = t
    end
    self:AddBlank(4)
    self:Resize()
    return Label
end

-- ── TOGGLE ────────────────────────────────────────────────
function BaseGroupbox:AddToggle(Idx, Info)
    assert(Info.Text, "AddToggle: Missing `Text`.")

    local Toggle = {
        Value    = not not Info.Default;
        Type     = "Toggle";
        Callback = Info.Callback or function() end;
        Addons   = {};
    }

    local ToggleOuter = Phantom:Create("Frame", {
        BackgroundColor3 = Phantom.Black;
        BorderColor3     = Phantom.Black;
        Size             = UDim2.new(0,13,0,13);
        ZIndex           = 5;
        Parent           = self.Container;
    })
    Phantom:AddToRegistry(ToggleOuter, { BorderColor3 = "Black" })

    local ToggleInner = Phantom:Create("Frame", {
        BackgroundColor3 = Phantom.MainColor;
        BorderColor3     = Phantom.OutlineColor;
        BorderMode       = Enum.BorderMode.Inset;
        Size             = UDim2.new(1,0,1,0);
        ZIndex           = 6;
        Parent           = ToggleOuter;
    })
    Phantom:AddToRegistry(ToggleInner, { BackgroundColor3 = "MainColor"; BorderColor3 = "OutlineColor" })

    local ToggleLabel = Phantom:CreateLabel({
        Size           = UDim2.new(0,210,1,0);
        Position       = UDim2.new(1,6,0,0);
        TextSize       = 13;
        Text           = Info.Text;
        TextXAlignment = Enum.TextXAlignment.Left;
        ZIndex         = 6;
        Parent         = ToggleInner;
    })
    Phantom:Create("UIListLayout", {
        Padding             = UDim.new(0,4);
        FillDirection       = Enum.FillDirection.Horizontal;
        HorizontalAlignment = Enum.HorizontalAlignment.Right;
        SortOrder           = Enum.SortOrder.LayoutOrder;
        Parent              = ToggleLabel;
    })

    -- Wider hover region
    local HitArea = Phantom:Create("Frame", {
        BackgroundTransparency = 1;
        Size                   = UDim2.new(0,180,1,0);
        ZIndex                 = 8;
        Parent                 = ToggleOuter;
    })
    Phantom:OnHighlight(HitArea, ToggleOuter,
        { BorderColor3 = "AccentColor" },
        { BorderColor3 = "Black" }
    )

    if type(Info.Tooltip) == "string" then
        Phantom:AddToolTip(Info.Tooltip, HitArea)
    end

    function Toggle:Display()
        ToggleInner.BackgroundColor3 = self.Value and Phantom.AccentColor or Phantom.MainColor
        ToggleInner.BorderColor3     = self.Value and Phantom.AccentColorDark or Phantom.OutlineColor
        local Reg = Phantom.RegistryMap[ToggleInner]
        if Reg then
            Reg.Properties.BackgroundColor3 = self.Value and "AccentColor" or "MainColor"
            Reg.Properties.BorderColor3     = self.Value and "AccentColorDark" or "OutlineColor"
        end
    end

    function Toggle:SetValue(Bool)
        self.Value = not not Bool
        self:Display()
        for _, Addon in next, self.Addons do
            if Addon.Type == "KeyPicker" and Addon.SyncToggleState then
                Addon.Toggled = Bool
                Addon:Update()
            end
        end
        Phantom:SafeCallback(self.Callback, self.Value)
        Phantom:SafeCallback(self.Changed, self.Value)
        Phantom:UpdateDependencyBoxes()
    end

    function Toggle:OnChanged(Func)
        self.Changed = Func
        Func(self.Value)
    end

    HitArea.InputBegan:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1
        and not Phantom:MouseIsOverOpenedFrame() then
            Toggle:SetValue(not Toggle.Value)
            Phantom:AttemptSave()
        end
    end)

    Toggle:Display()
    self:AddBlank(Info.BlankSize or 6)
    self:Resize()

    Toggle.TextLabel = ToggleLabel
    Toggle.Container = self.Container
    setmetatable(Toggle, BaseGroupbox)

    Toggles[Idx] = Toggle
    Phantom:UpdateDependencyBoxes()

    return Toggle
end

-- ── SLIDER ────────────────────────────────────────────────
function BaseGroupbox:AddSlider(Idx, Info)
    assert(Info.Text,    "AddSlider: Missing `Text`.")
    assert(Info.Min,     "AddSlider: Missing `Min`.")
    assert(Info.Max,     "AddSlider: Missing `Max`.")
    assert(Info.Default ~= nil, "AddSlider: Missing `Default`.")
    assert(Info.Rounding ~= nil, "AddSlider: Missing `Rounding`.")

    local MaxSize = 230

    local Slider = {
        Value    = Info.Default;
        Min      = Info.Min;
        Max      = Info.Max;
        Rounding = Info.Rounding;
        MaxSize  = MaxSize;
        Type     = "Slider";
        Callback = Info.Callback or function() end;
    }

    if not Info.Compact then
        Phantom:CreateLabel({
            Size           = UDim2.new(1,0,0,13);
            TextSize       = 13;
            Text           = Info.Text;
            TextXAlignment = Enum.TextXAlignment.Left;
            TextYAlignment = Enum.TextYAlignment.Bottom;
            ZIndex         = 5;
            Parent         = self.Container;
        })
        self:AddBlank(2)
    end

    local SliderOuter = Phantom:Create("Frame", {
        BackgroundColor3 = Phantom.Black;
        BorderColor3     = Phantom.Black;
        Size             = UDim2.new(1,-4,0,13);
        ZIndex           = 5;
        Parent           = self.Container;
    })
    Phantom:AddToRegistry(SliderOuter, { BorderColor3 = "Black" })

    local SliderInner = Phantom:Create("Frame", {
        BackgroundColor3 = Phantom.MainColor;
        BorderColor3     = Phantom.OutlineColor;
        BorderMode       = Enum.BorderMode.Inset;
        Size             = UDim2.new(1,0,1,0);
        ZIndex           = 6;
        Parent           = SliderOuter;
    })
    Phantom:AddToRegistry(SliderInner, { BackgroundColor3 = "MainColor"; BorderColor3 = "OutlineColor" })

    local Fill = Phantom:Create("Frame", {
        BackgroundColor3 = Phantom.AccentColor;
        BorderColor3     = Phantom.AccentColorDark;
        Size             = UDim2.new(0,0,1,0);
        ZIndex           = 7;
        Parent           = SliderInner;
    })
    Phantom:AddToRegistry(Fill, { BackgroundColor3 = "AccentColor"; BorderColor3 = "AccentColorDark" })

    local BorderHide = Phantom:Create("Frame", {
        BackgroundColor3 = Phantom.AccentColor;
        BorderSizePixel  = 0;
        Position         = UDim2.new(1,0,0,0);
        Size             = UDim2.new(0,1,1,0);
        ZIndex           = 8;
        Parent           = Fill;
    })
    Phantom:AddToRegistry(BorderHide, { BackgroundColor3 = "AccentColor" })

    local DisplayLabel = Phantom:CreateLabel({
        Size     = UDim2.new(1,0,1,0);
        TextSize = 13;
        Text     = "";
        ZIndex   = 9;
        Parent   = SliderInner;
    })

    Phantom:OnHighlight(SliderOuter, SliderOuter,
        { BorderColor3 = "AccentColor" },
        { BorderColor3 = "Black" }
    )

    if type(Info.Tooltip) == "string" then
        Phantom:AddToolTip(Info.Tooltip, SliderOuter)
    end

    local function Round(v)
        if Slider.Rounding == 0 then return math.floor(v) end
        return tonumber(string.format("%." .. Slider.Rounding .. "f", v))
    end

    function Slider:Display()
        local Suffix = Info.Suffix or ""
        if Info.Compact then
            DisplayLabel.Text = Info.Text .. ": " .. self.Value .. Suffix
        elseif Info.HideMax then
            DisplayLabel.Text = tostring(self.Value) .. Suffix
        else
            DisplayLabel.Text = self.Value .. Suffix .. " / " .. self.Max .. Suffix
        end
        local X = math.ceil(((self.Value - self.Min) / (self.Max - self.Min)) * self.MaxSize)
        Fill.Size = UDim2.new(0, X, 1, 0)
        BorderHide.Visible = X ~= self.MaxSize and X ~= 0
    end

    function Slider:SetValue(Str)
        local Num = tonumber(Str)
        if not Num then return end
        Num = math.clamp(Num, self.Min, self.Max)
        self.Value = Round(Num)
        self:Display()
        Phantom:SafeCallback(self.Callback, self.Value)
        Phantom:SafeCallback(self.Changed, self.Value)
    end

    function Slider:OnChanged(Func)
        self.Changed = Func
        Func(self.Value)
    end

    SliderInner.InputBegan:Connect(function(Input)
        if Input.UserInputType ~= Enum.UserInputType.MouseButton1
        or Phantom:MouseIsOverOpenedFrame() then return end

        local mPos = Mouse.X
        local gPos = Fill.Size.X.Offset
        local Diff = mPos - (Fill.AbsolutePosition.X + gPos)

        while InputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) do
            local nX = math.clamp(gPos + (Mouse.X - mPos) + Diff, 0, MaxSize)
            local nV = Round(Slider.Min + (nX / MaxSize) * (Slider.Max - Slider.Min))
            local Old = Slider.Value
            Slider.Value = nV
            Slider:Display()
            if nV ~= Old then
                Phantom:SafeCallback(Slider.Callback, Slider.Value)
                Phantom:SafeCallback(Slider.Changed, Slider.Value)
            end
            RenderStepped:Wait()
        end
        Phantom:AttemptSave()
    end)

    Slider:Display()
    self:AddBlank(Info.BlankSize or 5)
    self:Resize()

    Options[Idx] = Slider
    return Slider
end

-- ── BUTTON ────────────────────────────────────────────────
function BaseGroupbox:AddButton(Info)
    -- Accepts table or (text, func)
    local Text, Func, DoubleClick, Tooltip
    if type(Info) == "table" then
        Text        = Info.Text
        Func        = Info.Func
        DoubleClick = Info.DoubleClick
        Tooltip     = Info.Tooltip
    else
        Text = Info
        Func = select(1, ...)
    end
    assert(type(Func) == "function", "AddButton: Missing `Func` callback.")

    local Button = { Text = Text; Func = Func; DoubleClick = DoubleClick }

    local function MakeOuter()
        local Outer = Phantom:Create("Frame", {
            BackgroundColor3 = Phantom.Black;
            BorderColor3     = Phantom.Black;
            Size             = UDim2.new(1,-4,0,20);
            ZIndex           = 5;
            Parent           = self.Container;
        })
        local Inner = Phantom:Create("Frame", {
            BackgroundColor3 = Phantom.MainColor;
            BorderColor3     = Phantom.OutlineColor;
            BorderMode       = Enum.BorderMode.Inset;
            Size             = UDim2.new(1,0,1,0);
            ZIndex           = 6;
            Parent           = Outer;
        })
        Phantom:Create("UIGradient", {
            Color    = ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.new(1,1,1)),
                ColorSequenceKeypoint.new(1, Color3.fromRGB(212,212,212)),
            });
            Rotation = 90;
            Parent   = Inner;
        })
        local Label = Phantom:CreateLabel({
            Size     = UDim2.new(1,0,1,0);
            TextSize = 13;
            Text     = Text;
            ZIndex   = 7;
            Parent   = Inner;
        })
        Phantom:AddToRegistry(Outer, { BorderColor3 = "Black" })
        Phantom:AddToRegistry(Inner, { BackgroundColor3 = "MainColor"; BorderColor3 = "OutlineColor" })
        Phantom:OnHighlight(Outer, Outer,
            { BorderColor3 = "AccentColor" },
            { BorderColor3 = "Black" }
        )
        return Outer, Inner, Label
    end

    Button.Outer, Button.Inner, Button.Label = MakeOuter()

    local function WaitForClick(event, timeout)
        local fired = false
        local conn
        conn = event:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                fired = true
                conn:Disconnect()
            end
        end)
        local t = 0
        while not fired and t < timeout do
            t = t + RunService.Heartbeat:Wait()
        end
        conn:Disconnect()
        return fired
    end

    Button.Outer.InputBegan:Connect(function(Input)
        if Input.UserInputType ~= Enum.UserInputType.MouseButton1
        or Phantom:MouseIsOverOpenedFrame() then return end
        if Button.Locked then return end

        if DoubleClick then
            Phantom:RemoveFromRegistry(Button.Label)
            Phantom:AddToRegistry(Button.Label, { TextColor3 = "AccentColor" })
            Button.Label.TextColor3 = Phantom.AccentColor
            Button.Label.Text       = "Are you sure?"
            Button.Locked           = true
            local clicked = WaitForClick(Button.Outer.InputBegan, 0.5)
            Phantom:RemoveFromRegistry(Button.Label)
            Phantom:AddToRegistry(Button.Label, { TextColor3 = "FontColor" })
            Button.Label.TextColor3 = Phantom.FontColor
            Button.Label.Text       = Text
            task.defer(rawset, Button, "Locked", false)
            if clicked then Phantom:SafeCallback(Func) end
            return
        end

        Phantom:SafeCallback(Func)
    end)

    if type(Tooltip) == "string" then
        Phantom:AddToolTip(Tooltip, Button.Outer)
    end

    self:AddBlank(4)
    self:Resize()

    return Button
end

