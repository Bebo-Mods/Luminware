        BackgroundTransparency = 1;
        Position               = UDim2.new(0,5,0,0);
        Size                   = UDim2.new(1,-5,1,0);
        Font                   = Phantom.Font;
        PlaceholderColor3      = Color3.fromRGB(80,80,80);
        PlaceholderText        = "Hex color";
        Text                   = "#FFFFFF";
        TextColor3             = Phantom.FontColor;
