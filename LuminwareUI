    -- Keybind container HUD label
    local ContainerLabel = Phantom:CreateLabel({
        TextXAlignment = Enum.TextXAlignment.Left;
        Size           = UDim2.new(1,0,0,18);
        TextSize       = 13;
        Visible        = false;
        ZIndex         = 110;
        Parent         = Phantom.KeybindContainer;
    }, true)

    -- Mode selector
    local Modes = Info.Modes or { "Always", "Toggle", "Hold" }
    if KeyPicker.SyncToggleState then Modes = { "Toggle" } end

    local ModeOuter = Phantom:Create("Frame", {
        BorderColor3 = Phantom.Black;
        Size         = UDim2.new(0,60,0, #Modes*15+2);
        Visible      = false;
        ZIndex       = 14;
        Parent       = ScreenGui;
    })
    local ModeInner = Phantom:Create("Frame", {
        BackgroundColor3 = Phantom.BackgroundColor;
        BorderColor3     = Phantom.OutlineColor;
        BorderMode       = Enum.BorderMode.Inset;
        Size             = UDim2.new(1,0,1,0);
        ZIndex           = 15;
        Parent           = ModeOuter;
    })
    Phantom:AddToRegistry(ModeInner, { BackgroundColor3 = "BackgroundColor"; BorderColor3 = "OutlineColor" })
    Phantom:Create("UIListLayout", {
        FillDirection = Enum.FillDirection.Vertical;
        SortOrder     = Enum.SortOrder.LayoutOrder;
        Parent        = ModeInner;
