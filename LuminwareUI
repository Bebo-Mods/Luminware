-- ============================================================
-- REGISTRY HELPERS
-- ============================================================
function Phantom:AddToRegistry(Inst, Properties, IsHud)
    local Data = {
        Instance   = Inst;
        Properties = Properties;
    }
    table.insert(self.Registry, Data)
    self.RegistryMap[Inst] = Data
    if IsHud then
        table.insert(self.HudRegistry, Data)
    end
end

function Phantom:RemoveFromRegistry(Inst)
    local Data = self.RegistryMap[Inst]
    if not Data then return end
    for i = #self.Registry, 1, -1 do
        if self.Registry[i] == Data then
            table.remove(self.Registry, i)
        end
    end
    for i = #self.HudRegistry, 1, -1 do
        if self.HudRegistry[i] == Data then
            table.remove(self.HudRegistry, i)
        end
    end
    self.RegistryMap[Inst] = nil
end

function Phantom:UpdateColorsUsingRegistry()
    for _, Object in next, self.Registry do
        for Property, ColorIdx in next, Object.Properties do
            if type(ColorIdx) == "string" then
                Object.Instance[Property] = self[ColorIdx]
            elseif type(ColorIdx) == "function" then
                Object.Instance[Property] = ColorIdx()
            end
        end
    end
end

function Phantom:GetDarkerColor(Color)
    local H, S, V = Color3.toHSV(Color)
    return Color3.fromHSV(H, S, V / 1.5)
end

-- ============================================================
-- SIGNAL MANAGEMENT
-- ============================================================
function Phantom:GiveSignal(Signal)
    table.insert(self.Signals, Signal)
end

function Phantom:Unload()
    for i = #self.Signals, 1, -1 do
        local conn = table.remove(self.Signals, i)
        pcall(function() conn:Disconnect() end)
    end
    if type(self.OnUnload) == "function" then
        pcall(self.OnUnload)
    end
    ScreenGui:Destroy()
end

-- Clean up registry when instances are destroyed
Phantom:GiveSignal(ScreenGui.DescendantRemoving:Connect(function(Inst)
    if Phantom.RegistryMap[Inst] then
        Phantom:RemoveFromRegistry(Inst)
    end
end))

-- ============================================================
-- INSTANCE HELPERS
-- ============================================================
function Phantom:Create(Class, Properties)
    local Inst = type(Class) == "string" and Instance.new(Class) or Class
    for k, v in next, Properties do
        if k ~= "Parent" then
            Inst[k] = v
        end
    end
    if Properties.Parent then
        Inst.Parent = Properties.Parent
    end
    return Inst
end

function Phantom:ApplyTextStroke(Inst)
    Inst.TextStrokeTransparency = 1
    self:Create("UIStroke", {
        Color        = Color3.new(0,0,0);
        Thickness    = 1;
        LineJoinMode = Enum.LineJoinMode.Miter;
        Parent       = Inst;
    })
end

function Phantom:CreateLabel(Properties, IsHud)
    local Inst = self:Create("TextLabel", {
        BackgroundTransparency = 1;
        Font                   = self.Font;
        TextColor3             = self.FontColor;
        TextSize               = 14;
        TextStrokeTransparency = 0;
    })
    self:ApplyTextStroke(Inst)
    self:AddToRegistry(Inst, { TextColor3 = "FontColor" }, IsHud)
    return self:Create(Inst, Properties)
end

function Phantom:GetTextBounds(Text, Font, Size, Resolution)
    local B = TextService:GetTextSize(Text, Size, Font, Resolution or Vector2.new(1920, 1080))
    return B.X, B.Y
end

function Phantom:SafeCallback(f, ...)
    if not f then return end
    if not self.NotifyOnError then return f(...) end
    local ok, err = pcall(f, ...)
    if not ok then
        local _, i = err:find(":%d+: ")
        self:Notify(i and err:sub(i+1) or err, 3)
    end
end

function Phantom:AttemptSave()
    if self.SaveManager then
        self.SaveManager:Save()
    end
end

function Phantom:UpdateDependencyBoxes()
    for _, Depbox in next, self.DependencyBoxes do
        Depbox:Update()
    end
end

-- ============================================================
-- MOUSE HELPERS
-- ============================================================
function Phantom:MouseIsOverOpenedFrame()
    for Frame in next, self.OpenedFrames do
        local p, s = Frame.AbsolutePosition, Frame.AbsoluteSize
        if Mouse.X >= p.X and Mouse.X <= p.X + s.X
        and Mouse.Y >= p.Y and Mouse.Y <= p.Y + s.Y then
            return true
        end
    end
end

function Phantom:IsMouseOverFrame(Frame)
    local p, s = Frame.AbsolutePosition, Frame.AbsoluteSize
    return Mouse.X >= p.X and Mouse.X <= p.X + s.X
       and Mouse.Y >= p.Y and Mouse.Y <= p.Y + s.Y
end

-- ============================================================
-- DRAGGABLE
-- ============================================================
function Phantom:MakeDraggable(Frame, Cutoff)
    Frame.Active = true
    Frame.InputBegan:Connect(function(Input)
        if Input.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
        local ObjPos = Vector2.new(
            Mouse.X - Frame.AbsolutePosition.X,
            Mouse.Y - Frame.AbsolutePosition.Y
        )
        if ObjPos.Y > (Cutoff or 9999) then return end
        while InputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) do
            Frame.Position = UDim2.new(
                0, Mouse.X - ObjPos.X + (Frame.Size.X.Offset * Frame.AnchorPoint.X),
                0, Mouse.Y - ObjPos.Y + (Frame.Size.Y.Offset * Frame.AnchorPoint.Y)
            )
            RenderStepped:Wait()
        end
    end)
end

-- ============================================================
-- HIGHLIGHT HELPER
-- ============================================================
function Phantom:OnHighlight(HoverInst, Inst, Props, Defaults)
    HoverInst.MouseEnter:Connect(function()
        local Reg = self.RegistryMap[Inst]
        for Property, ColorIdx in next, Props do
            Inst[Property] = self[ColorIdx] or ColorIdx
            if Reg and Reg.Properties[Property] then
                Reg.Properties[Property] = ColorIdx
            end
        end
    end)
    HoverInst.MouseLeave:Connect(function()
        local Reg = self.RegistryMap[Inst]
        for Property, ColorIdx in next, Defaults do
            Inst[Property] = self[ColorIdx] or ColorIdx
            if Reg and Reg.Properties[Property] then
                Reg.Properties[Property] = ColorIdx
            end
        end
    end)
end

-- ============================================================
-- TOOLTIP
-- ============================================================
function Phantom:AddToolTip(Text, HoverInst)
    local X, Y = self:GetTextBounds(Text, self.Font, 13)
    local Frame = self:Create("Frame", {
        BackgroundColor3 = self.MainColor;
        BorderColor3     = self.OutlineColor;
        Size             = UDim2.fromOffset(X + 8, Y + 6);
        ZIndex           = 100;
        Visible          = false;
        Parent           = ScreenGui;
    })
    local Label = self:CreateLabel({
        Position         = UDim2.fromOffset(4, 2);
        Size             = UDim2.fromOffset(X, Y);
        TextSize         = 13;
        Text             = Text;
        TextXAlignment   = Enum.TextXAlignment.Left;
        ZIndex           = 101;
        Parent           = Frame;
    })
    self:AddToRegistry(Frame, { BackgroundColor3 = "MainColor"; BorderColor3 = "OutlineColor" })
    self:AddToRegistry(Label, { TextColor3 = "FontColor" })

    local hovering = false
    HoverInst.MouseEnter:Connect(function()
        if self:MouseIsOverOpenedFrame() then return end
        hovering = true
        Frame.Position = UDim2.fromOffset(Mouse.X + 15, Mouse.Y + 12)
        Frame.Visible  = true
        while hovering do
            RunService.Heartbeat:Wait()
            Frame.Position = UDim2.fromOffset(Mouse.X + 15, Mouse.Y + 12)
        end
    end)
    HoverInst.MouseLeave:Connect(function()
        hovering      = false
        Frame.Visible = false
    end)
end

